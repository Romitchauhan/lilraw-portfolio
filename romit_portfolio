<script>
/* CURSOR */
const cd=document.getElementById('cd'),cr=document.getElementById('cr');
let mx=0,my=0,rx=0,ry=0;
document.addEventListener('mousemove',e=>{mx=e.clientX;my=e.clientY;});
(function t(){cd.style.left=mx+'px';cd.style.top=my+'px';rx+=(mx-rx)*.1;ry+=(my-ry)*.1;cr.style.left=rx+'px';cr.style.top=ry+'px';requestAnimationFrame(t);})();
document.querySelectorAll('a,button,.pc,.vc,.rc,.tc,.wc').forEach(el=>{
  el.addEventListener('mouseenter',()=>document.body.classList.add('cur-grow'));
  el.addEventListener('mouseleave',()=>document.body.classList.remove('cur-grow'));
});

/* NAV */
const nav=document.getElementById('nav');
window.addEventListener('scroll',()=>nav.classList.toggle('s',scrollY>60));

/* REVEAL */
const obs=new IntersectionObserver(entries=>{
  entries.forEach(e=>{
    if(e.isIntersecting){
      e.target.classList.add('on');
      e.target.querySelectorAll('.sk-fi').forEach(b=>b.classList.add('an'));
    }
  });
},{threshold:.1});
document.querySelectorAll('.r').forEach(el=>obs.observe(el));
new IntersectionObserver(entries=>{
  if(entries[0].isIntersecting) entries[0].target.querySelectorAll('.sk-fi').forEach(b=>b.classList.add('an'));
},{threshold:.2}).observe(document.querySelector('.sk-list')||document.body);

/* FILTER */
function filt(btn,cat){
  document.querySelectorAll('.ptab').forEach(b=>b.classList.remove('on'));
  btn.classList.add('on');
  document.querySelectorAll('.pc').forEach(c=>{
    const show=cat==='all'||c.dataset.cat===cat;
    c.style.opacity=show?'1':'0.12';
    c.style.pointerEvents=show?'auto':'none';
  });
}

/* LIGHTBOX */
const lbImgs=[
  {src:"data:image/jpeg;base64,",cap:"Slide 01 · Brand Identity"},
  {src:"data:image/jpeg;base64,",cap:"Slide 02 · Philosophy"},
  {src:"data:image/jpeg;base64,",cap:"Slide 03 · Video Editing"},
  {src:"data:image/jpeg;base64,",cap:"Slide 04 · Motion Graphics"},
  {src:"data:image/jpeg;base64,",cap:"Slide 05 · Sound Design"},
  {src:"data:image/jpeg;base64,",cap:"Slide 06 · YouTube & Reels"},
  {src:"data:image/jpeg;base64,",cap:"Slide 07 · Call To Action"},
  {src:"data:image/jpeg;base64,",cap:"Hoarding · Billboard Mockup"},
  {src:"data:image/jpeg;base64,",cap:"Web · Portfolio Website"},
];
const lbVids=[
  {src:"data:image/jpeg;base64,",cap:"Sunset Resort Landscape · 4K"},
  {src:"data:image/jpeg;base64,",cap:"Cinematic B-Roll Edit · 4K"},
  {src:"data:image/jpeg;base64,",cap:"Nature & Travel Film · 4K"},
];
let lbi=0,lbt='img';
const lb=document.getElementById('lb'),lbimg=document.getElementById('lbi'),lbcap=document.getElementById('lbc');
function openLB(i){lbt='img';lbi=i;lb.classList.add('on');document.body.style.overflow='hidden';setLB();}
function openLBv(i){lbt='vid';lbi=i;lb.classList.add('on');document.body.style.overflow='hidden';setLB();}
function closeLB(){lb.classList.remove('on');document.body.style.overflow='';}
function movLB(d){const a=lbt==='img'?lbImgs:lbVids;lbi=(lbi+d+a.length)%a.length;setLB();}
function setLB(){const a=lbt==='img'?lbImgs:lbVids;lbimg.src=a[lbi].src;lbcap.textContent=a[lbi].cap;}
document.getElementById('lbx').addEventListener('click',closeLB);
document.getElementById('lbp').addEventListener('click',e=>{e.stopPropagation();movLB(-1);});
document.getElementById('lbn').addEventListener('click',e=>{e.stopPropagation();movLB(1);});
lb.addEventListener('click',e=>{if(e.target===lb)closeLB();});
document.addEventListener('keydown',e=>{
  if(!lb.classList.contains('on'))return;
  if(e.key==='Escape')closeLB();
  if(e.key==='ArrowLeft')movLB(-1);
  if(e.key==='ArrowRight')movLB(1);
});
